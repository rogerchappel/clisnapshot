{
  "snapshotDir": "__snapshots__",
  "fixturesDir": "fixtures",
  "defaultTimeoutMs": 5000,
  "scrubbers": [
    { "pattern": "v\\d+\\.\\d+\\.\\d+", "replacement": "v<VERSION>" }
  ],
  "cases": {
    "help-output": {
      "command": "node",
      "args": ["fixtures/bin/example-cli.mjs", "--help"],
      "snapshot": "help-output.snap"
    },
    "noisy-output": {
      "command": "node",
      "args": ["fixtures/bin/example-cli.mjs", "noisy"],
      "snapshot": "noisy-output.snap"
    }
  }
}
