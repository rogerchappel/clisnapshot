{
  "name": "clisnapshot",
  "version": "0.1.0",
  "description": "Stable snapshots for terminal output without the confetti drift.",
  "type": "module",
  "bin": {
    "clisnapshot": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist .smoke-tmp",
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "node --test tests/*.test.mjs",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "snapshot-testing",
    "terminal",
    "ansi",
    "testing",
    "fixtures"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/clisnapshot.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/clisnapshot/issues"
  },
  "homepage": "https://github.com/rogerchappel/clisnapshot#readme"
}
